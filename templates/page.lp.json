{
  "sections": {
    "lp_hero": {
      "type": "hero",
      "blocks": {
        "season_text": {
          "type": "text",
          "settings": {
            "text": "<h6>2026 Autumn / Winter</h6>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "h6"
          }
        },
        "main_heading": {
          "type": "text",
          "settings": {
            "text": "<h1>From Range to Town</h1>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
            "type_preset": "h1"
          }
        },
        "tagline_text": {
          "type": "text",
          "settings": {
            "text": "<p>山から街へ。機能とデザインが溶け合う、新しいアウトドアウェア。</p>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
            "type_preset": "rte"
          }
        },
        "spacer_1": {
          "type": "spacer",
          "settings": {
            "size": "pixel",
            "pixel_size": 24
          }
        },
        "cta_button": {
          "type": "button",
          "settings": {
            "label": "Explore Collection",
            "link": "shopify://collections/all-product-1"
          }
        }
      },
      "block_order": [
        "season_text",
        "main_heading",
        "tagline_text",
        "spacer_1",
        "cta_button"
      ],
      "name": "Hero",
      "settings": {
        "content_direction": "column",
        "vertical_on_mobile": true,
        "horizontal_alignment_flex_direction_column": "flex-start",
        "vertical_alignment_flex_direction_column": "flex-end",
        "gap": 12,
        "section_width": "page-width",
        "section_height": "full-screen",
        "color_scheme": "scheme-6",
        "toggle_overlay": true,
        "overlay_color": "#00000080",
        "overlay_style": "gradient",
        "gradient_direction": "to top",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    },
    "lp_divider": {
      "type": "divider",
      "name": "Divider",
      "settings": {
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "thickness": 0.5,
        "width_percent": 30,
        "alignment_horizontal": "center",
        "padding-block-start": 60,
        "padding-block-end": 60
