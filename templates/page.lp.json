                  "settings": {
                    "text": "<h3>機能が宿る、都市の衣服</h3>",
                    "type_preset": "h3"
                  }
                },
                "description": {
                  "type": "text",
                  "settings": {
                    "text": "<p>ANETOは、トレッキングやランニングで培った高機能素材を、都市生活にフィットするデザインへ昇華。防水・透湿・軽量といったアウトドアの機能を、街に溶け込むミニマルなフォルムに凝縮しました。</p>",
                    "type_preset": "rte",
                    "max_width": "narrow"
                  }
                }
              },
              "block_order": ["heading", "description"]
            },
            "about_button": {
              "type": "button",
              "settings": {
                "label": "About ANETO",
                "link": "",
                "style_class": "link"
              }
            }
          },
          "block_order": ["caption", "heading_group", "about_button"]
        }
      },
      "name": "ブランドフィロソフィー",
